# Required in the browser and for npm development: the public API route of one
# Better Ecommerce Admin store. Replace YOUR_STORE_ID with the admin store ID.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/YOUR_STORE_ID

# Required for npm server rendering: the same API from the local host.
STORE_API_URL=http://localhost:3000/api/YOUR_STORE_ID

# Required for Docker server rendering: the same API through Docker's host
# gateway. The browser continues to use NEXT_PUBLIC_API_URL above.
DOCKER_STORE_API_URL=http://host.docker.internal:3000/api/YOUR_STORE_ID

# Optional: host port used by the storefront containers.
APP_PORT=3001
